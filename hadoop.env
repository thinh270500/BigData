CORE_CONF_fs_defaultFS=hdfs://hadoop-master:9000
CORE_CONF_hadoop_http_staticuser_user=root
CORE_CONF_hadoop_proxyuser_hue_hosts=*
CORE_CONF_hadoop_proxyuser_hue_groups=*

HDFS_CONF_dfs_replication=2
HDFS_CONF_dfs_permissions_enabled=false

YARN_CONF_yarn_resourcemanager_hostname=hadoop-master
YARN_CONF_yarn_nodemanager_resource_memory_mb=1024
YARN_CONF_yarn_scheduler_maximum_allocation_mb=1024
YARN_CONF_yarn_scheduler_minimum_allocation_mb=256
YARN_CONF_yarn_nodemanager_vmem_check_enabled=false

MAPRED_CONF_mapreduce_framework_name=yarn
MAPRED_CONF_mapreduce_map_memory_mb=512
MAPRED_CONF_mapreduce_reduce_memory_mb=512

DB_DRIVER=postgresql
DB_HOST=hive-postgres
DB_USER=hive
DB_PASS=hive